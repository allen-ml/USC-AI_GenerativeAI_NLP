#!/usr/bin/env bash
# Pre-commit hook — runs checks and warns but never blocks the commit.

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

FAILED=()

run_check() {
  local label="$1"
  shift
  printf "  checking %-20s" "$label..."
  if "$@" > /tmp/hook-out 2>&1; then
    printf "${GREEN}ok${NC}\n"
  else
    printf "${RED}FAIL${NC}\n"
    FAILED+=("$label")
    cat /tmp/hook-out | sed 's/^/    /'
  fi
}

echo ""
echo "Pre-commit checks (warnings only — commit will not be blocked)"
echo "───────────────────────────────────────────────────────────────"

run_check "typecheck" npm run typecheck --silent
run_check "lint"      npm run lint --silent
run_check "build"     npm run build --silent

echo ""

if [ ${#FAILED[@]} -eq 0 ]; then
  printf "${GREEN}All checks passed.${NC}\n\n"
else
  printf "${YELLOW}Warning: the following checks failed: ${FAILED[*]}${NC}\n"
  printf "These issues will block the CI merge check — fix them before opening a PR.\n\n"
fi

# Always exit 0 so the commit is never blocked locally.
exit 0
